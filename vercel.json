{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next@latest"
    },
    {
      "src": "backend/package.json",
      "use": "@vercel/node@latest",
      "config": {
        "includeFiles": "backend/dist/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/.*",
      "dest": "backend/dist/main",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"]
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {},
  "github": {
    "enabled": false
  }
}
