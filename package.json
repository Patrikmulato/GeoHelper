{
  "name": "geoguessr-helper",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "predev": "pnpm sync:data:pull",
    "dev": "next dev",
    "dev:backend": "pnpm sync:data:pull && pnpm --filter geoguessr-helper-backend dev",
    "build": "next build",
    "build:backend": "pnpm sync:data:pull && pnpm --filter geoguessr-helper-backend build",
    "sync:data": "pnpm --filter geoguessr-helper-backend sync:data",
    "sync:data:pull": "pnpm --filter geoguessr-helper-backend sync:data:pull",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "leaflet": "1.9.4",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@types/leaflet": "1.9.21",
    "@types/node": "20.19.39",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": "node ./scripts/lint-staged-tsc.js",
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --no-ignore",
      "prettier --write",
      "jest --bail --findRelatedTests"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
